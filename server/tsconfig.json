{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true
  },
  "ts-node": {
    "esm": true,
    "preferTsExts": true
  },
  "include": ["index.ts", "routes/**/*.ts", "utils/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
